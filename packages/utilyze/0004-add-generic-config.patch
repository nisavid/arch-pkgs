--- utilyze-0.1.1.orig/internal/config/config_test.go	1969-12-31 19:00:00.000000000 -0500
+++ utilyze-0.1.1/internal/config/config_test.go	2026-04-23 21:28:40.381343086 -0400
@@ -0,0 +1,175 @@
+package config
+
+import (
+	"errors"
+	"os"
+	"path/filepath"
+	"testing"
+)
+
+func TestManagerPathsUseXDGLayout(t *testing.T) {
+	t.Parallel()
+
+	manager := &Manager{
+		userConfigDir:    func() (string, error) { return "/home/test/.config", nil },
+		systemConfigDirs: func() []string { return []string{"/etc/xdg", "/opt/xdg"} },
+	}
+
+	userPath, err := manager.UserPath()
+	if err != nil {
+		t.Fatalf("UserPath() error = %v", err)
+	}
+	if want := filepath.Join("/home/test/.config", "utilyze", "config.toml"); userPath != want {
+		t.Fatalf("UserPath() = %q, want %q", userPath, want)
+	}
+
+	systemPaths := manager.SystemPaths()
+	want := []string{
+		filepath.Join("/etc/xdg", "utilyze", "config.toml"),
+		filepath.Join("/opt/xdg", "utilyze", "config.toml"),
+	}
+	if len(systemPaths) != len(want) {
+		t.Fatalf("SystemPaths() = %#v, want %#v", systemPaths, want)
+	}
+	for i := range want {
+		if systemPaths[i] != want[i] {
+			t.Fatalf("SystemPaths()[%d] = %q, want %q", i, systemPaths[i], want[i])
+		}
+	}
+}
+
+func TestManagerLoadMissingFilesIsClean(t *testing.T) {
+	t.Parallel()
+
+	base := t.TempDir()
+	manager := testManager(base, []string{filepath.Join(base, "system")})
+
+	result := manager.Load()
+	if len(result.Notices) != 0 {
+		t.Fatalf("Load().Notices = %#v, want none", result.Notices)
+	}
+	if result.UserPath != filepath.Join(base, "user", "utilyze", "config.toml") {
+		t.Fatalf("Load().UserPath = %q", result.UserPath)
+	}
+}
+
+func TestManagerLoadInvalidSystemAndUserConfigReturnsNotices(t *testing.T) {
+	t.Parallel()
+
+	base := t.TempDir()
+	systemDir := filepath.Join(base, "system")
+	userDir := filepath.Join(base, "user")
+	writeConfig(t, systemDir, "not toml =")
+	writeConfig(t, userDir, "also not toml =")
+
+	manager := testManager(base, []string{systemDir})
+	result := manager.Load()
+	if len(result.Notices) != 2 {
+		t.Fatalf("Load().Notices = %#v, want two notices", result.Notices)
+	}
+	for _, notice := range result.Notices {
+		if notice.Code != NoticeLoadFailed {
+			t.Fatalf("notice.Code = %q, want %q", notice.Code, NoticeLoadFailed)
+		}
+	}
+}
+
+func TestManagerLoadUserIgnoresSystemConfig(t *testing.T) {
+	t.Parallel()
+
+	base := t.TempDir()
+	systemDir := filepath.Join(base, "system")
+	writeConfig(t, systemDir, "not toml =")
+
+	manager := testManager(base, []string{systemDir})
+	result := manager.LoadUser()
+	if len(result.Notices) != 0 {
+		t.Fatalf("LoadUser().Notices = %#v, want none", result.Notices)
+	}
+	if result.UserPath != filepath.Join(base, "user", "utilyze", "config.toml") {
+		t.Fatalf("LoadUser().UserPath = %q", result.UserPath)
+	}
+}
+
+func TestManagerSaveUserCreatesSecureConfigAtomically(t *testing.T) {
+	t.Parallel()
+
+	base := t.TempDir()
+	manager := testManager(base, nil)
+
+	result, err := manager.SaveUser(Config{})
+	if err != nil {
+		t.Fatalf("SaveUser() error = %v", err)
+	}
+	if result.Notice != nil {
+		t.Fatalf("SaveUser().Notice = %#v, want nil", result.Notice)
+	}
+
+	configDir := filepath.Join(base, "user", "utilyze")
+	configPath := filepath.Join(configDir, "config.toml")
+	if result.Path != configPath {
+		t.Fatalf("SaveUser().Path = %q, want %q", result.Path, configPath)
+	}
+
+	dirInfo, err := os.Stat(configDir)
+	if err != nil {
+		t.Fatalf("Stat(configDir) error = %v", err)
+	}
+	if got := dirInfo.Mode().Perm(); got != 0o700 {
+		t.Fatalf("config dir mode = %o, want %o", got, 0o700)
+	}
+
+	fileInfo, err := os.Stat(configPath)
+	if err != nil {
+		t.Fatalf("Stat(configPath) error = %v", err)
+	}
+	if got := fileInfo.Mode().Perm(); got != 0o600 {
+		t.Fatalf("config file mode = %o, want %o", got, 0o600)
+	}
+
+	entries, err := os.ReadDir(configDir)
+	if err != nil {
+		t.Fatalf("ReadDir(configDir) error = %v", err)
+	}
+	if len(entries) != 1 || entries[0].Name() != "config.toml" {
+		t.Fatalf("config dir entries = %#v, want only config.toml", entries)
+	}
+}
+
+func TestManagerSaveUserPathFailureReturnsNotice(t *testing.T) {
+	t.Parallel()
+
+	manager := &Manager{
+		userConfigDir: func() (string, error) { return "", errors.New("no config home") },
+	}
+
+	result, err := manager.SaveUser(Config{})
+	if err == nil {
+		t.Fatal("SaveUser() error = nil, want non-nil")
+	}
+	if result.Notice == nil || result.Notice.Code != NoticeSaveFailed {
+		t.Fatalf("SaveUser().Notice = %#v, want save-failed notice", result.Notice)
+	}
+}
+
+func testManager(base string, systemDirs []string) *Manager {
+	return &Manager{
+		userConfigDir: func() (string, error) {
+			return filepath.Join(base, "user"), nil
+		},
+		systemConfigDirs: func() []string {
+			return systemDirs
+		},
+	}
+}
+
+func writeConfig(t *testing.T, base string, body string) {
+	t.Helper()
+	path := filepath.Join(base, "utilyze", "config.toml")
+	if err := os.MkdirAll(filepath.Dir(path), 0o700); err != nil {
+		t.Fatalf("MkdirAll() error = %v", err)
+	}
+	if err := os.WriteFile(path, []byte(body), 0o600); err != nil {
+		t.Fatalf("WriteFile() error = %v", err)
+	}
+}
