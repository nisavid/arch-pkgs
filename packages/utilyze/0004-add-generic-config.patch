diff -ruN '--exclude=build' '--exclude=dist' utilyze-0.1.1.orig/internal/tui/screens/top/status_notice_test.go utilyze-0.1.1/internal/tui/screens/top/status_notice_test.go
--- utilyze-0.1.1.orig/internal/tui/screens/top/status_notice_test.go	1969-12-31 19:00:00.000000000 -0500
+++ utilyze-0.1.1/internal/tui/screens/top/status_notice_test.go	2026-04-23 21:28:04.981023638 -0400
@@ -0,0 +1,52 @@
+package top
+
+import (
+	"strings"
+	"testing"
+	"time"
+
+	tea "charm.land/bubbletea/v2"
+)
+
+func TestStatusNoticeShowsOnceAndExpires(t *testing.T) {
+	t.Parallel()
+
+	now := time.Date(2026, 4, 23, 12, 0, 0, 0, time.UTC)
+	m := initStatusNoticeModel(t, New(96, 24,
+		WithNow(func() time.Time { return now }),
+		WithStatusNoticeDuration(6*time.Second),
+	))
+
+	m = updateStatusNoticeModel(t, m, StatusNoticeMsg{Code: "config-load-failed", Text: "config unreadable"})
+	m = updateStatusNoticeModel(t, m, StatusNoticeMsg{Code: "config-load-failed", Text: "replacement text should be ignored"})
+
+	view := m.View().Content
+	if !strings.Contains(view, "config unreadable") {
+		t.Fatalf("View() missing active notice:\n%s", view)
+	}
+	if strings.Contains(view, "replacement text should be ignored") {
+		t.Fatalf("View() used duplicate notice text:\n%s", view)
+	}
+
+	now = now.Add(7 * time.Second)
+	m = updateStatusNoticeModel(t, m, drawMsg{})
+	if view := m.View().Content; strings.Contains(view, "config unreadable") {
+		t.Fatalf("View() still shows expired notice:\n%s", view)
+	}
+}
+
+func initStatusNoticeModel(t *testing.T, m model) model {
+	t.Helper()
+	return updateStatusNoticeModel(t, m, InitMsg{DeviceIDs: []int{0}})
+}
+
+func updateStatusNoticeModel(t *testing.T, m model, msg tea.Msg) model {
