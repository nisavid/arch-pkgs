diff -ruN '--exclude=build' '--exclude=dist' utilyze-0.1.1.orig/internal/config/config.go utilyze-0.1.1/internal/config/config.go
--- utilyze-0.1.1.orig/internal/config/config.go	1969-12-31 19:00:00.000000000 -0500
+++ utilyze-0.1.1/internal/config/config.go	2026-04-23 21:28:40.319346028 -0400
@@ -0,0 +1,285 @@
+package config
+
+import (
+	"errors"
+	"io"
+	"os"
+	"path/filepath"
+	"strings"
+
+	"github.com/BurntSushi/toml"
+)
+
+const (
+	AppDirName     = "utilyze"
+	ConfigFileName = "config.toml"
+)
+
+type Config struct{}
+
+type NoticeCode string
+
+const (
+	NoticeLoadFailed NoticeCode = "config-load-failed"
+	NoticeSaveFailed NoticeCode = "config-save-failed"
+)
+
+type Notice struct {
+	Code NoticeCode
+	Path string
+	Err  error
+}
+
+type LoadResult struct {
+	Config      Config
+	Notices     []Notice
+	UserPath    string
+	SystemPaths []string
+}
+
+type SaveResult struct {
+	Path   string
+	Notice *Notice
+}
+
+type Manager struct {
+	userConfigDir    func() (string, error)
+	systemConfigDirs func() []string
+	fileOps          fileOps
+}
+
+func NewManager() *Manager {
+	return &Manager{
+		userConfigDir:    os.UserConfigDir,
+		systemConfigDirs: defaultSystemConfigDirs,
+		fileOps:          osFileOps{},
+	}
+}
+
+func (m *Manager) UserPath() (string, error) {
+	configHome, err := m.userDir()
+	if err != nil {
+		return "", err
+	}
+	return filepath.Join(configHome, AppDirName, ConfigFileName), nil
+}
+
+func (m *Manager) SystemPaths() []string {
+	dirs := m.systemDirs()
+	paths := make([]string, 0, len(dirs))
+	for _, dir := range dirs {
+		if dir == "" {
+			continue
+		}
+		paths = append(paths, filepath.Join(dir, AppDirName, ConfigFileName))
+	}
+	return paths
+}
+
+func (m *Manager) Load() LoadResult {
+	result := LoadResult{
+		SystemPaths: m.SystemPaths(),
+	}
+
+	for i := len(result.SystemPaths) - 1; i >= 0; i-- {
+		cfg, notice, ok := m.loadFile(result.SystemPaths[i])
+		if notice != nil {
+			result.Notices = append(result.Notices, *notice)
+		}
+		if ok {
+			Merge(&result.Config, cfg)
+		}
+	}
+
+	userPath, err := m.UserPath()
+	if err != nil {
+		result.Notices = append(result.Notices, Notice{Code: NoticeLoadFailed, Err: err})
+		return result
+	}
+	result.UserPath = userPath
+
+	cfg, notice, ok := m.loadFile(userPath)
+	if notice != nil {
+		result.Notices = append(result.Notices, *notice)
+	}
+	if ok {
+		Merge(&result.Config, cfg)
+	}
+
+	return result
+}
+
+func (m *Manager) LoadUser() LoadResult {
+	result := LoadResult{}
+	userPath, err := m.UserPath()
+	if err != nil {
+		result.Notices = append(result.Notices, Notice{Code: NoticeLoadFailed, Err: err})
+		return result
+	}
+	result.UserPath = userPath
+
+	cfg, notice, ok := m.loadFile(userPath)
+	if notice != nil {
+		result.Notices = append(result.Notices, *notice)
+	}
+	if ok {
+		result.Config = cfg
+	}
+	return result
+}
+
+func (m *Manager) SaveUser(config Config) (SaveResult, error) {
+	configPath, err := m.UserPath()
+	if err != nil {
+		return SaveResult{Notice: &Notice{Code: NoticeSaveFailed, Err: err}}, err
+	}
+
+	configDir := filepath.Dir(configPath)
+	ops := m.files()
+	if err := ops.MkdirAll(configDir, 0o700); err != nil {
+		return saveFailure(configPath, err)
+	}
+	if err := ops.Chmod(configDir, 0o700); err != nil {
+		return saveFailure(configPath, err)
+	}
+
+	tempFile, err := ops.CreateTemp(configDir, ConfigFileName+".*.tmp")
+	if err != nil {
+		return saveFailure(configPath, err)
+	}
+	tempPath := tempFile.Name()
+	keepTemp := false
+	defer func() {
+		if !keepTemp {
+			_ = ops.Remove(tempPath)
+		}
+	}()
+
+	if err := tempFile.Chmod(0o600); err != nil {
+		_ = tempFile.Close()
+		return saveFailure(configPath, err)
+	}
+	if err := toml.NewEncoder(tempFile).Encode(config); err != nil {
+		_ = tempFile.Close()
+		return saveFailure(configPath, err)
+	}
+	if err := tempFile.Close(); err != nil {
+		return saveFailure(configPath, err)
+	}
+	if err := ops.Rename(tempPath, configPath); err != nil {
+		return saveFailure(configPath, err)
+	}
+
+	keepTemp = true
+	return SaveResult{Path: configPath}, nil
+}
+
+func Merge(dst *Config, src Config) {
+	_ = dst
+	_ = src
+}
+
+func (m *Manager) loadFile(path string) (Config, *Notice, bool) {
+	file, err := m.files().Open(path)
+	if err != nil {
+		if errors.Is(err, os.ErrNotExist) {
+			return Config{}, nil, false
+		}
+		return Config{}, &Notice{Code: NoticeLoadFailed, Path: path, Err: err}, false
+	}
+	defer file.Close()
+
+	var config Config
+	if _, err := toml.NewDecoder(file).Decode(&config); err != nil {
+		return Config{}, &Notice{Code: NoticeLoadFailed, Path: path, Err: err}, false
+	}
+	return config, nil, true
+}
+
+func (m *Manager) userDir() (string, error) {
+	if m != nil && m.userConfigDir != nil {
+		return m.userConfigDir()
+	}
+	return os.UserConfigDir()
+}
+
+func (m *Manager) systemDirs() []string {
+	if m != nil && m.systemConfigDirs != nil {
+		return m.systemConfigDirs()
+	}
+	return defaultSystemConfigDirs()
+}
+
+func (m *Manager) files() fileOps {
+	if m != nil && m.fileOps != nil {
+		return m.fileOps
+	}
+	return osFileOps{}
+}
+
+func defaultSystemConfigDirs() []string {
+	value := os.Getenv("XDG_CONFIG_DIRS")
+	if value == "" {
+		return []string{"/etc/xdg"}
+	}
+	parts := strings.Split(value, string(os.PathListSeparator))
+	dirs := make([]string, 0, len(parts))
+	for _, part := range parts {
+		if part != "" {
+			dirs = append(dirs, part)
+		}
+	}
+	if len(dirs) == 0 {
+		return []string{"/etc/xdg"}
+	}
+	return dirs
+}
+
+func saveFailure(path string, err error) (SaveResult, error) {
+	return SaveResult{
+		Path:   path,
+		Notice: &Notice{Code: NoticeSaveFailed, Path: path, Err: err},
+	}, err
+}
+
+type tempFile interface {
+	io.Writer
+	Chmod(os.FileMode) error
+	Close() error
+	Name() string
+}
+
+type fileOps interface {
+	Open(string) (io.ReadCloser, error)
+	MkdirAll(string, os.FileMode) error
+	Chmod(string, os.FileMode) error
+	CreateTemp(string, string) (tempFile, error)
+	Rename(string, string) error
+	Remove(string) error
+}
+
+type osFileOps struct{}
+
+func (osFileOps) Open(name string) (io.ReadCloser, error) {
+	return os.Open(name)
+}
+
+func (osFileOps) MkdirAll(path string, perm os.FileMode) error {
+	return os.MkdirAll(path, perm)
+}
+
+func (osFileOps) Chmod(name string, mode os.FileMode) error {
+	return os.Chmod(name, mode)
+}
+
+func (osFileOps) CreateTemp(dir string, pattern string) (tempFile, error) {
+	return os.CreateTemp(dir, pattern)
+}
+
+func (osFileOps) Rename(oldpath string, newpath string) error {
+	return os.Rename(oldpath, newpath)
+}
+
+func (osFileOps) Remove(name string) error {
+	return os.Remove(name)
+}
