 func HasProfilingCapabilities() (bool, error) {
+	if hasCaps, err := hasCapSysAdmin(); err != nil || hasCaps {
+		return hasCaps, err
+	}
+
+	allowed, err := profilingAllowedForAllUsers()
+	if err != nil {
+		// Keep the warning when the current driver policy cannot be confirmed.
+		return false, nil
+	}
+	return allowed, nil
+}
+
+func profilingAllowedForAllUsers() (bool, error) {
+	file, err := os.Open("/proc/driver/nvidia/params")
+	if err != nil {
+		return false, err
+	}
+	defer file.Close()
+
+	scanner := bufio.NewScanner(file)
+	for scanner.Scan() {
+		key, value, ok := strings.Cut(scanner.Text(), ":")
+		if ok && strings.TrimSpace(key) == "RmProfilingAdminOnly" {
+			return strings.TrimSpace(value) == "0", nil
+		}
+	}
+	return false, scanner.Err()
+}
+
+func hasCapSysAdmin() (bool, error) {
 	// version 3 capabilities are 64 bit and need to twice-wide for lower/higher bits
 	hdr := unix.CapUserHeader{Version: unix.LINUX_CAPABILITY_VERSION_3}
 	data := [2]unix.CapUserData{}
