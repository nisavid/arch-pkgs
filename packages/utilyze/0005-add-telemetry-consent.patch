+
+func TestConsentRowVisibleOnlyWhenEnabledByState(t *testing.T) {
+	t.Parallel()
+
+	visible := initTelemetryModel(t, New(96, 24,
+		WithTelemetryConsentHandler(func(TelemetryConsentAction) TelemetryConsentResult {
+			return TelemetryConsentResult{}
+		}),
+	))
+	visible = updateTelemetryModel(t, visible, TelemetryConsentStateMsg{Visible: true})
+	if view := visible.View().Content; !strings.Contains(view, "a=Accept") {
+		t.Fatalf("View() missing consent hints:\n%s", view)
+	}
+
+	hidden := initTelemetryModel(t, New(96, 24,
+		WithTelemetryConsentHandler(func(TelemetryConsentAction) TelemetryConsentResult {
+			return TelemetryConsentResult{}
+		}),
+	))
+	if view := hidden.View().Content; strings.Contains(view, "a=Accept") {
+		t.Fatalf("View() unexpectedly contains consent hints:\n%s", view)
+	}
+}
+
+func TestConsentKeysTriggerExpectedActions(t *testing.T) {
+	t.Parallel()
+
+	cases := []struct {
+		name   string
+		key    tea.KeyPressMsg
+		action TelemetryConsentAction
+	}{
+		{name: "accept", key: tea.KeyPressMsg(tea.Key{Text: "a", Code: 'a'}), action: TelemetryConsentAccept},
+		{name: "reject", key: tea.KeyPressMsg(tea.Key{Text: "x", Code: 'x'}), action: TelemetryConsentReject},
+		{name: "dismiss", key: tea.KeyPressMsg(tea.Key{Code: tea.KeyEscape}), action: TelemetryConsentDismiss},
+	}
+
+	for _, tc := range cases {
+		tc := tc
+		t.Run(tc.name, func(t *testing.T) {
+			t.Parallel()
+
+			var gotAction TelemetryConsentAction
+			m := initTelemetryModel(t, New(96, 24,
+				WithTelemetryConsentHandler(func(action TelemetryConsentAction) TelemetryConsentResult {
+					gotAction = action
+					return TelemetryConsentResult{ConsentVisible: false}
+				}),
+			))
+			m = updateTelemetryModel(t, m, TelemetryConsentStateMsg{Visible: true})
+			m = updateTelemetryModel(t, m, tc.key)
+
+			if gotAction != tc.action {
+				t.Fatalf("got action %q, want %q", gotAction, tc.action)
+			}
+			if view := m.View().Content; strings.Contains(view, "a=Accept") {
+				t.Fatalf("View() still contains consent hints after %s:\n%s", tc.name, view)
+			}
+		})
+	}
+}
+
+func TestStatusNoticeTakesPrecedenceOverConsentRow(t *testing.T) {
+	t.Parallel()
+
+	m := initTelemetryModel(t, New(96, 24,
+		WithTelemetryConsentHandler(func(TelemetryConsentAction) TelemetryConsentResult {
+			return TelemetryConsentResult{}
+		}),
+	))
+	m = updateTelemetryModel(t, m, TelemetryConsentStateMsg{Visible: true})
+	m = updateTelemetryModel(t, m, StatusNoticeMsg{Code: "load-failed", Text: "config unreadable"})
+
+	view := m.View().Content
+	if !strings.Contains(view, "config unreadable") {
+		t.Fatalf("View() missing active notice:\n%s", view)
+	}
+	if strings.Contains(view, "a=Accept") {
+		t.Fatalf("View() shows consent while notice is active:\n%s", view)
+	}
+}
+
+func TestNarrowConsentRowPreservesKeyHints(t *testing.T) {
+	t.Parallel()
+
+	m := initTelemetryModel(t, New(80, 24,
+		WithTelemetryConsentHandler(func(TelemetryConsentAction) TelemetryConsentResult {
+			return TelemetryConsentResult{}
+		}),
+	))
+	m = updateTelemetryModel(t, m, TelemetryConsentStateMsg{Visible: true})
+
+	view := m.View().Content
+	for _, hint := range []string{"a=Accept", "x=Reject", "esc=Dismiss"} {
+		if !strings.Contains(view, hint) {
+			t.Fatalf("View() missing key hint %q:\n%s", hint, view)
+		}
+	}
+	if telemetryConsentCopy != "Share anonymous telemetry to improve Attainable SOL for this effective user." {
+		t.Fatalf("telemetryConsentCopy = %q, want current consent copy", telemetryConsentCopy)
+	}
+	if strings.Contains(view, telemetryConsentCopy) {
+		t.Fatalf("View() did not truncate the full consent copy on a narrow layout:\n%s", view)
+	}
+}
+
+func initTelemetryModel(t *testing.T, m model) model {
+	t.Helper()
+	return updateTelemetryModel(t, m, InitMsg{DeviceIDs: []int{0}})
+}
+
+func updateTelemetryModel(t *testing.T, m model, msg tea.Msg) model {
+	t.Helper()
+
+	next, _ := m.Update(msg)
+	typed, ok := next.(model)
+	if !ok {
+		t.Fatalf("Update(%T) returned %T, want model", msg, next)
+	}
+	return typed
+}
