+++ utilyze-0.1.1/internal/telemetry/controller.go	2026-04-23 21:31:21.043729365 -0400
@@ -0,0 +1,104 @@
+package telemetry
+
+import (
+	"github.com/systalyze/utilyze/internal/config"
+	"github.com/systalyze/utilyze/internal/tui/screens/top"
+)
+
+const (
+	ConfigLoadFailedNoticeCode = "telemetry-config-load-failed"
+	SaveFailedNoticeCode       = "telemetry-save-failed"
+)
+
+type ConfigManager interface {
+	ResolveTelemetry(config.TelemetrySessionState) config.TelemetryResolution
+	SaveTelemetry(bool) (config.SaveResult, error)
+	UserPath() (string, error)
+}
+
+type Reporter interface {
+	SetEnabled(bool)
+}
+
+type ApplyResult struct {
+	Resolution config.TelemetryResolution
+	Notice     *top.StatusNoticeMsg
+}
+
+type Controller struct {
+	manager    ConfigManager
+	reporter   Reporter
+	session    config.TelemetrySessionState
+	resolution config.TelemetryResolution
+}
+
+func NewController(manager ConfigManager, reporter Reporter) *Controller {
+	c := &Controller{
+		manager:  manager,
+		reporter: reporter,
+	}
+	c.refresh()
+	return c
+}
+
+func (c *Controller) Resolution() config.TelemetryResolution {
+	return c.resolution
+}
+
+func (c *Controller) BindReporter(reporter Reporter) {
+	c.reporter = reporter
+	c.applyReporterState()
+}
+
+func (c *Controller) InitialNotice() *top.StatusNoticeMsg {
+	for _, notice := range c.resolution.Notices {
+		if notice.Code == config.NoticeLoadFailed {
+			return &top.StatusNoticeMsg{
+				Code: ConfigLoadFailedNoticeCode,
+				Text: "Config could not be loaded; telemetry preference was not applied.",
+			}
+		}
+	}
+	return nil
+}
+
+func (c *Controller) Apply(action top.TelemetryConsentAction) ApplyResult {
+	switch action {
+	case top.TelemetryConsentAccept:
+		return c.applyDecision(true)
+	case top.TelemetryConsentReject:
+		return c.applyDecision(false)
+	case top.TelemetryConsentDismiss:
+		c.session.Dismissed = true
+		c.session.Decision = nil
+		c.refresh()
+	}
+	return ApplyResult{Resolution: c.resolution}
+}
+
+func (c *Controller) applyDecision(enabled bool) ApplyResult {
+	c.session.Decision = &enabled
+	c.session.Dismissed = false
+
+	var notice *top.StatusNoticeMsg
+	if _, err := c.manager.SaveTelemetry(enabled); err != nil {
+		notice = &top.StatusNoticeMsg{
+			Code: SaveFailedNoticeCode,
+			Text: "Telemetry preference could not be saved; this choice applies to this session only.",
+		}
+	}
+	c.refresh()
+	return ApplyResult{Resolution: c.resolution, Notice: notice}
+}
+
+func (c *Controller) refresh() {
+	c.resolution = c.manager.ResolveTelemetry(c.session)
+	c.applyReporterState()
+}
+
+func (c *Controller) applyReporterState() {
+	if c.reporter == nil {
+		return
+	}
+	c.reporter.SetEnabled(c.resolution.Decision == config.TelemetryDecisionEnabled)
+}
