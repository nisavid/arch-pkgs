+package metrics
+
+import "testing"
+
+func TestReporterUsesExplicitEnabledFlag(t *testing.T) {
+	t.Parallel()
+
+	reporter := New(ReporterConfig{
+		Enabled: false,
+	})
+	if reporter == nil {
+		t.Fatal("New() = nil, want reporter instance")
+	}
+	if reporter.Enabled() {
+		t.Fatal("Enabled() = true, want false")
+	}
+}
+
+func TestBackendOverrideDoesNotEnableReporter(t *testing.T) {
+	t.Setenv("UTLZ_BACKEND_URL", "https://metrics.example.test")
+
+	reporter := New(ReporterConfig{
+		Enabled: false,
+	})
+	if reporter == nil {
+		t.Fatal("New() = nil, want reporter instance")
+	}
+	if reporter.Enabled() {
+		t.Fatal("Enabled() = true, want false")
+	}
+	if reporter.config.BackendURL != "https://metrics.example.test" {
+		t.Fatalf("BackendURL = %q, want env override", reporter.config.BackendURL)
+	}
+}
