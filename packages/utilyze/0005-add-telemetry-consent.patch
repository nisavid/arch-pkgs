@@ -0,0 +1,133 @@
+package config
+
+import (
+	"os"
+	"path/filepath"
+	"testing"
+)
+
+func TestTelemetryResolutionMergesSystemAndUserConfig(t *testing.T) {
+	t.Parallel()
+
+	base := t.TempDir()
+	systemDir := filepath.Join(base, "system")
+	userDir := filepath.Join(base, "user")
+	writeConfig(t, systemDir, "[telemetry]\nenabled = true\n")
+	writeConfig(t, userDir, "[telemetry]\nenabled = false\n")
+
+	manager := &Manager{
+		userConfigDir:    func() (string, error) { return userDir, nil },
+		systemConfigDirs: func() []string { return []string{systemDir} },
+	}
+
+	got := manager.ResolveTelemetry(TelemetrySessionState{})
+	assertTelemetryResolution(t, got, TelemetryDecisionDisabled, TelemetrySourceConfigDisabled, false)
+}
+
+func TestTelemetryResolutionUsesSystemConfigWhenUserConfigIsMissing(t *testing.T) {
+	t.Parallel()
+
+	base := t.TempDir()
+	systemDir := filepath.Join(base, "system")
+	writeConfig(t, systemDir, "[telemetry]\nenabled = true\n")
+
+	manager := &Manager{
+		userConfigDir:    func() (string, error) { return filepath.Join(base, "user"), nil },
+		systemConfigDirs: func() []string { return []string{systemDir} },
+	}
+
+	got := manager.ResolveTelemetry(TelemetrySessionState{})
+	assertTelemetryResolution(t, got, TelemetryDecisionEnabled, TelemetrySourceConfigEnabled, false)
+}
+
+func TestTelemetryResolutionPromptsWhenNoConfigExists(t *testing.T) {
+	t.Parallel()
+
+	manager := testManager(t.TempDir(), nil)
+	got := manager.ResolveTelemetry(TelemetrySessionState{})
+	assertTelemetryResolution(t, got, TelemetryDecisionUndecided, TelemetrySourceNone, true)
+}
+
+func TestTelemetryResolutionHardDisableSuppressesPrompt(t *testing.T) {
+	t.Setenv("UTLZ_DISABLE_METRICS", "1")
+
+	manager := testManager(t.TempDir(), nil)
+	yes := true
+	got := manager.ResolveTelemetry(TelemetrySessionState{Decision: &yes})
+	assertTelemetryResolution(t, got, TelemetryDecisionDisabled, TelemetrySourceDisabledByEnv, false)
+}
+
+func TestTelemetryResolutionSessionAndDismissPrecedence(t *testing.T) {
+	t.Parallel()
+
+	manager := testManager(t.TempDir(), nil)
+
+	yes := true
+	got := manager.ResolveTelemetry(TelemetrySessionState{Decision: &yes})
+	assertTelemetryResolution(t, got, TelemetryDecisionEnabled, TelemetrySourceSession, false)
+
+	no := false
+	got = manager.ResolveTelemetry(TelemetrySessionState{Decision: &no})
+	assertTelemetryResolution(t, got, TelemetryDecisionDisabled, TelemetrySourceSession, false)
+
+	got = manager.ResolveTelemetry(TelemetrySessionState{Dismissed: true})
+	assertTelemetryResolution(t, got, TelemetryDecisionDisabled, TelemetrySourceSessionDismissed, false)
+}
+
+func TestTelemetryResolutionInvalidConfigReturnsNoticeAndPrompts(t *testing.T) {
+	t.Parallel()
+
+	base := t.TempDir()
+	userDir := filepath.Join(base, "user")
+	writeConfig(t, userDir, "[telemetry]\nenabled = nope\n")
+	manager := &Manager{
+		userConfigDir:    func() (string, error) { return userDir, nil },
+		systemConfigDirs: func() []string { return nil },
+	}
+
+	got := manager.ResolveTelemetry(TelemetrySessionState{})
+	assertTelemetryResolution(t, got, TelemetryDecisionUndecided, TelemetrySourceNone, true)
+	if len(got.Notices) != 1 || got.Notices[0].Code != NoticeLoadFailed {
+		t.Fatalf("Resolution.Notices = %#v, want one load-failed notice", got.Notices)
+	}
+}
+
+func TestSaveTelemetryWritesUserConfigOnly(t *testing.T) {
+	t.Parallel()
+
+	base := t.TempDir()
+	systemDir := filepath.Join(base, "system")
+	userDir := filepath.Join(base, "user")
+	writeConfig(t, systemDir, "[telemetry]\nenabled = false\n")
+
+	manager := &Manager{
+		userConfigDir:    func() (string, error) { return userDir, nil },
+		systemConfigDirs: func() []string { return []string{systemDir} },
+	}
+	if _, err := manager.SaveTelemetry(true); err != nil {
+		t.Fatalf("SaveTelemetry(true) error = %v", err)
+	}
+
+	userConfig, err := os.ReadFile(filepath.Join(userDir, "utilyze", "config.toml"))
+	if err != nil {
+		t.Fatalf("ReadFile(user config) error = %v", err)
+	}
+	if got := string(userConfig); got != "[telemetry]\n  enabled = true\n" {
+		t.Fatalf("user config = %q, want telemetry enabled", got)
+	}
+
+	systemConfig, err := os.ReadFile(filepath.Join(systemDir, "utilyze", "config.toml"))
+	if err != nil {
+		t.Fatalf("ReadFile(system config) error = %v", err)
+	}
+	if got := string(systemConfig); got != "[telemetry]\nenabled = false\n" {
+		t.Fatalf("system config = %q, want unchanged", got)
+	}
+}
+
+func assertTelemetryResolution(t *testing.T, got TelemetryResolution, wantDecision TelemetryDecision, wantSource TelemetrySource, wantPrompt bool) {
+	t.Helper()
+	if got.Decision != wantDecision || got.Source != wantSource || got.Prompt != wantPrompt {
+		t.Fatalf("Resolution = %#v, want decision=%q source=%q prompt=%v", got, wantDecision, wantSource, wantPrompt)
+	}
+}
