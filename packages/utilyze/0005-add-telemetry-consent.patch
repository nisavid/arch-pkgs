+	if s.userPathFunc != nil {
+		return s.userPathFunc()
+	}
+	return "", nil
+}
+
+type stubReporter struct {
+	enabled bool
+}
+
+func (s *stubReporter) SetEnabled(enabled bool) {
+	s.enabled = enabled
+}
+
+type assertErr string
+
+func (e assertErr) Error() string { return string(e) }
+
+type persistentManager struct {
+	persisted *bool
+}
+
+func (p *persistentManager) ResolveTelemetry(session config.TelemetrySessionState) config.TelemetryResolution {
+	if session.Decision != nil {
+		if *session.Decision {
+			return config.TelemetryResolution{
+				Decision: config.TelemetryDecisionEnabled,
+				Source:   config.TelemetrySourceSession,
+			}
+		}
+		return config.TelemetryResolution{
+			Decision: config.TelemetryDecisionDisabled,
+			Source:   config.TelemetrySourceSession,
+		}
+	}
+	if session.Dismissed {
+		return config.TelemetryResolution{
+			Decision: config.TelemetryDecisionDisabled,
+			Source:   config.TelemetrySourceSessionDismissed,
+		}
+	}
+	if p.persisted == nil {
+		return config.TelemetryResolution{
+			Decision: config.TelemetryDecisionUndecided,
+			Prompt:   true,
+		}
+	}
+	if *p.persisted {
+		return config.TelemetryResolution{
+			Decision: config.TelemetryDecisionEnabled,
+			Source:   config.TelemetrySourceConfigEnabled,
+		}
+	}
+	return config.TelemetryResolution{
+		Decision: config.TelemetryDecisionDisabled,
+		Source:   config.TelemetrySourceConfigDisabled,
+	}
+}
+
+func (p *persistentManager) SaveTelemetry(enabled bool) (config.SaveResult, error) {
+	p.persisted = new(bool)
+	*p.persisted = enabled
+	return config.SaveResult{}, nil
+}
+
+func (p *persistentManager) UserPath() (string, error) {
+	return "", nil
+}
