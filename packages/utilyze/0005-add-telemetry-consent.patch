diff -ruN '--exclude=build' '--exclude=dist' '--exclude=embedded' utilyze-0.1.1.orig/internal/config/telemetry.go utilyze-0.1.1/internal/config/telemetry.go
--- utilyze-0.1.1.orig/internal/config/telemetry.go	1969-12-31 19:00:00.000000000 -0500
+++ utilyze-0.1.1/internal/config/telemetry.go	2026-04-23 21:29:59.754579086 -0400
@@ -0,0 +1,93 @@
+package config
+
+import "os"
+
+const telemetryDisableEnvVar = "UTLZ_DISABLE_METRICS"
+
+type TelemetryDecision string
+
+const (
+	TelemetryDecisionEnabled   TelemetryDecision = "enabled"
+	TelemetryDecisionDisabled  TelemetryDecision = "disabled"
+	TelemetryDecisionUndecided TelemetryDecision = "undecided"
+)
+
+type TelemetrySource string
+
+const (
+	TelemetrySourceNone             TelemetrySource = ""
+	TelemetrySourceDisabledByEnv    TelemetrySource = "disabled-by-env"
+	TelemetrySourceSession          TelemetrySource = "session"
+	TelemetrySourceSessionDismissed TelemetrySource = "session-dismissed"
+	TelemetrySourceConfigEnabled    TelemetrySource = "config-enabled"
+	TelemetrySourceConfigDisabled   TelemetrySource = "config-disabled"
+)
+
+type TelemetrySessionState struct {
+	Decision  *bool
+	Dismissed bool
+}
+
+type TelemetryResolution struct {
+	Decision TelemetryDecision
+	Source   TelemetrySource
+	Prompt   bool
+	Notices  []Notice
+}
+
+func (m *Manager) ResolveTelemetry(session TelemetrySessionState) TelemetryResolution {
+	if os.Getenv(telemetryDisableEnvVar) == "1" {
+		return TelemetryResolution{
+			Decision: TelemetryDecisionDisabled,
+			Source:   TelemetrySourceDisabledByEnv,
+		}
+	}
+
+	if session.Decision != nil {
+		if *session.Decision {
+			return TelemetryResolution{
+				Decision: TelemetryDecisionEnabled,
+				Source:   TelemetrySourceSession,
+			}
+		}
+		return TelemetryResolution{
+			Decision: TelemetryDecisionDisabled,
+			Source:   TelemetrySourceSession,
+		}
+	}
+
+	if session.Dismissed {
+		return TelemetryResolution{
+			Decision: TelemetryDecisionDisabled,
+			Source:   TelemetrySourceSessionDismissed,
+		}
+	}
+
+	load := m.Load()
+	if load.Config.Telemetry.Enabled == nil {
+		return TelemetryResolution{
+			Decision: TelemetryDecisionUndecided,
+			Prompt:   true,
+			Notices:  load.Notices,
+		}
+	}
+	if *load.Config.Telemetry.Enabled {
+		return TelemetryResolution{
+			Decision: TelemetryDecisionEnabled,
+			Source:   TelemetrySourceConfigEnabled,
+			Notices:  load.Notices,
+		}
+	}
+	return TelemetryResolution{
+		Decision: TelemetryDecisionDisabled,
+		Source:   TelemetrySourceConfigDisabled,
+		Notices:  load.Notices,
+	}
+}
+
+func (m *Manager) SaveTelemetry(enabled bool) (SaveResult, error) {
+	load := m.LoadUser()
+	config := load.Config
+	config.Telemetry.Enabled = &enabled
+	return m.SaveUser(config)
+}
