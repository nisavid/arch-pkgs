+package telemetry
+
+import (
+	"testing"
+
+	"github.com/systalyze/utilyze/internal/config"
+	"github.com/systalyze/utilyze/internal/tui/screens/top"
+)
+
+func TestSaveFailureAppliesChoiceForCurrentSessionOnly(t *testing.T) {
+	t.Parallel()
+
+	manager := &stubManager{
+		resolveFunc: func(session config.TelemetrySessionState) config.TelemetryResolution {
+			if session.Decision != nil && *session.Decision {
+				return config.TelemetryResolution{
+					Decision: config.TelemetryDecisionEnabled,
+					Source:   config.TelemetrySourceSession,
+				}
+			}
+			return config.TelemetryResolution{
+				Decision: config.TelemetryDecisionUndecided,
+				Prompt:   true,
+			}
+		},
+		saveFunc: func(bool) (config.SaveResult, error) {
+			return config.SaveResult{Notice: &config.Notice{Code: config.NoticeSaveFailed}}, assertErr("save failed")
+		},
+	}
+	reporter := &stubReporter{}
+
+	controller := NewController(manager, reporter)
+	result := controller.Apply(top.TelemetryConsentAccept)
+
+	if !reporter.enabled {
+		t.Fatal("reporter enabled = false, want true")
+	}
+	if result.Notice == nil || result.Notice.Code != SaveFailedNoticeCode {
+		t.Fatalf("Apply().Notice = %#v, want save-failed notice", result.Notice)
+	}
+	if result.Resolution.Decision != config.TelemetryDecisionEnabled || result.Resolution.Prompt {
+		t.Fatalf("Apply().Resolution = %#v, want session-enabled with prompt suppressed", result.Resolution)
+	}
+
+	fresh := NewController(manager, &stubReporter{})
+	if got := fresh.Resolution(); got.Decision != config.TelemetryDecisionUndecided || !got.Prompt {
+		t.Fatalf("fresh Resolution() = %#v, want undecided prompt after failed save", got)
+	}
+}
+
+func TestPersistedChoicesSuppressBannerOnLaterLaunches(t *testing.T) {
+	t.Parallel()
+
+	manager := &persistentManager{}
+	accepted := NewController(manager, &stubReporter{})
+	if result := accepted.Apply(top.TelemetryConsentAccept); result.Notice != nil {
+		t.Fatalf("accept notice = %#v, want nil", result.Notice)
+	}
+
+	laterAccepted := NewController(manager, &stubReporter{})
+	if got := laterAccepted.Resolution(); got.Decision != config.TelemetryDecisionEnabled || got.Prompt {
+		t.Fatalf("later accepted Resolution() = %#v, want config enabled without prompt", got)
+	}
+
+	rejectedManager := &persistentManager{}
+	rejected := NewController(rejectedManager, &stubReporter{})
+	if result := rejected.Apply(top.TelemetryConsentReject); result.Notice != nil {
+		t.Fatalf("reject notice = %#v, want nil", result.Notice)
+	}
+
+	laterRejected := NewController(rejectedManager, &stubReporter{})
+	if got := laterRejected.Resolution(); got.Decision != config.TelemetryDecisionDisabled || got.Prompt {
+		t.Fatalf("later rejected Resolution() = %#v, want config disabled without prompt", got)
+	}
+}
+
+func TestDismissAppliesSessionOnlyDecisionAndFallsBackOnNextLaunch(t *testing.T) {
+	t.Parallel()
+
+	t.Run("undecided fallback", func(t *testing.T) {
+		t.Parallel()
+
+		manager := &persistentManager{}
+		reporter := &stubReporter{enabled: true}
+		controller := NewController(manager, reporter)
+
+		result := controller.Apply(top.TelemetryConsentDismiss)
+		if result.Notice != nil {
+			t.Fatalf("dismiss notice = %#v, want nil", result.Notice)
+		}
+		if got := result.Resolution; got.Decision != config.TelemetryDecisionDisabled || got.Source != config.TelemetrySourceSessionDismissed || got.Prompt {
+			t.Fatalf("dismiss Resolution() = %#v, want session-dismissed without prompt", got)
+		}
+		if reporter.enabled {
+			t.Fatal("reporter enabled = true, want false")
+		}
+
+		fresh := NewController(manager, &stubReporter{})
+		if got := fresh.Resolution(); got.Decision != config.TelemetryDecisionUndecided || !got.Prompt {
+			t.Fatalf("fresh Resolution() = %#v, want undecided prompt after session-only dismiss", got)
+		}
+	})
+
+	t.Run("config fallback", func(t *testing.T) {
+		t.Parallel()
+
+		persisted := true
+		manager := &persistentManager{persisted: &persisted}
+		controller := NewController(manager, &stubReporter{enabled: true})
+
+		result := controller.Apply(top.TelemetryConsentDismiss)
+		if result.Notice != nil {
+			t.Fatalf("dismiss notice = %#v, want nil", result.Notice)
+		}
+		if got := result.Resolution; got.Decision != config.TelemetryDecisionDisabled || got.Source != config.TelemetrySourceSessionDismissed || got.Prompt {
+			t.Fatalf("dismiss Resolution() = %#v, want session-dismissed without prompt", got)
+		}
+
+		fresh := NewController(manager, &stubReporter{})
+		if got := fresh.Resolution(); got.Decision != config.TelemetryDecisionEnabled || got.Source != config.TelemetrySourceConfigEnabled || got.Prompt {
+			t.Fatalf("fresh Resolution() = %#v, want config enabled without prompt after dismiss", got)
+		}
+	})
+}
+
+type stubManager struct {
+	resolveFunc  func(config.TelemetrySessionState) config.TelemetryResolution
+	saveFunc     func(bool) (config.SaveResult, error)
+	userPathFunc func() (string, error)
+}
+
+func (s *stubManager) ResolveTelemetry(session config.TelemetrySessionState) config.TelemetryResolution {
+	return s.resolveFunc(session)
+}
+
+func (s *stubManager) SaveTelemetry(enabled bool) (config.SaveResult, error) {
+	return s.saveFunc(enabled)
+}
+
