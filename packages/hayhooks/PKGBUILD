pkgname=hayhooks
pkgver=1.18.0
pkgrel=1
pkgdesc="Serve Haystack pipelines as REST endpoints"
arch=('any')
url="https://docs.haystack.deepset.ai/docs/hayhooks"
license=('Apache-2.0')
backup=('etc/hayhooks/hayhooks.env')
depends=('python' 'python-docstring-parser' 'python-fastapi' 'python-fastapi-openai-compat' 'python-haystack-ai' 'python-loguru' 'python-pydantic-settings' 'python-dotenv' 'python-python-multipart' 'python-requests' 'python-rich' 'python-typer' 'uvicorn')
makedepends=('python-build' 'python-hatch-vcs' 'python-hatchling' 'python-installer' 'python-wheel')
source=(
  "https://files.pythonhosted.org/packages/42/bd/85917f58d106fc1f4272c6d5a3ad03df69e034ac01e63fdd4c83c6d2c077/hayhooks-${pkgver}.tar.gz"
  'hayhooks.env'
  'hayhooks.service'
  'hayhooks.sysusers'
  'hayhooks.tmpfiles'
)
sha256sums=('cf2e0f33a793e72fef537a515aea101eb4895f1ecf130c37e6cc296a279a15fd'
            '9661219339ba2abaa582ae481a168e590ac19e5aab29e9ea3a33110dcf3f37bd'
            '21f1f73b1c05613f9276ede4e69f34d9415b47964bce9a9bdc648bd6594c64ac'
            '457ea692b071070e2eb00b75cbc9704304bfb092d46e67dcaffc5a70bf32a9aa'
            'f954b5d61f4f8b5664da4bb3594427b16f5bb17f9d0014efa8770205f8001a14')
prepare() {
  cd "hayhooks-${pkgver}"
  # The source distribution omits this empty hidden directory, but the wheel
  # build force-includes it.
  mkdir -p src/hayhooks/server/chainlit_app/.chainlit
}

build() {
  cd "hayhooks-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "hayhooks-${pkgver}"
  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 "${srcdir}/hayhooks.env" "${pkgdir}/etc/hayhooks/hayhooks.env"
  install -Dm644 "${srcdir}/hayhooks.service" "${pkgdir}/usr/lib/systemd/system/hayhooks.service"
  install -Dm644 "${srcdir}/hayhooks.sysusers" "${pkgdir}/usr/lib/sysusers.d/hayhooks.conf"
  install -Dm644 "${srcdir}/hayhooks.tmpfiles" "${pkgdir}/usr/lib/tmpfiles.d/hayhooks.conf"
}
