pkgname=python-backoff
pkgver=2.2.1
pkgrel=1
pkgdesc="Function decoration for backoff and retry"
arch=('any')
url="https://pypi.org/project/backoff/"
license=('MIT')
depends=('python')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
source=("https://files.pythonhosted.org/packages/47/d7/5bbeb12c44d7c4f2fb5b56abce497eb5ed9f34d85701de869acedd602619/backoff-${pkgver}.tar.gz")
sha256sums=('03f829f5bb1923180821643f8753b0502c3b682293992485b0eef2807afa5cba')

build() {
  cd "backoff-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "backoff-${pkgver}"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
