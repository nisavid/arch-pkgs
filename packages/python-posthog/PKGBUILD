pkgname=python-posthog
pkgver=7.13.0
pkgrel=1
pkgdesc="Integrate PostHog into Python applications"
arch=('any')
url="https://pypi.org/project/posthog/"
license=('MIT')
depends=('python' 'python-backoff' 'python-dateutil' 'python-distro' 'python-requests' 'python-typing_extensions')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
source=("https://files.pythonhosted.org/packages/e2/e8/e7890dcdacb7297b3f981b86a26b9538a505a0d0a4aa213a038aa1963561/posthog-${pkgver}.tar.gz")
sha256sums=('471295afc144972401b02cf96f635bc43f9527e1cde809b30c48a588e326e86a')

build() {
  cd "posthog-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "posthog-${pkgver}"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
