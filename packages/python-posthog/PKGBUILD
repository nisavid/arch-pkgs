pkgname=python-posthog
pkgver=7.13.1
pkgrel=1
pkgdesc="Integrate PostHog into Python applications"
arch=('any')
url="https://pypi.org/project/posthog/"
license=('MIT')
depends=('python' 'python-backoff' 'python-dateutil' 'python-distro' 'python-requests' 'python-typing_extensions')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
source=("https://files.pythonhosted.org/packages/2a/09/ecc82b5ba5876164a3807adcc5101466da1e4416600075bdbd2071327457/posthog-${pkgver}.tar.gz")
sha256sums=('5e53c57db076807530bbec5634c96673ceae8e8e58b99c983af26f02bb4759aa')

build() {
  cd "posthog-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "posthog-${pkgver}"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
